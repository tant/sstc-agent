{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": "../../..",
		"baseUrl": "../../..",
		"paths": {
			"@/*": ["src/*"]
		},
		"types": ["jest", "node"]
	},
	"include": ["**/*.ts", "../../../src/**/*"],
	"exclude": ["node_modules", "dist"]
}
